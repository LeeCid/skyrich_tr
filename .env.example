# Skyrich Battery TR — Environment Variables
# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env files to version control.

# PostgreSQL connection string (required by API server)
DATABASE_URL=

# Admin password for /admin login (required by API server)
# Generate a strong password. Do not use dictionary words.
ADMIN_PASSWORD=

# Admin API Bearer token secret (required by API server)
# Generate a long random string (e.g., 64+ chars). This is returned by /api/admin/login
# and must be presented in the Authorization: Bearer <token> header on all admin endpoints.
ADMIN_API_TOKEN=

# Frontend origin for CORS (optional, defaults to skyrichbattery.com.tr domains)
# Set this if the frontend is hosted on a different domain than the API.
FRONTEND_ORIGIN=https://www.skyrichbattery.com.tr

# API base URL used by the frontend (optional in dev, required in production if API is separate)
# Example: https://api.skyrichbattery.com.tr
VITE_API_BASE_URL=

# Vite build base path (required by frontend build)
BASE_PATH=/

# Port for the API server (required by API server)
# The frontend Vite dev server also reads this for its own port in the current config.
PORT=3000
