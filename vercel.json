{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/skyrich-tr run build",
  "outputDirectory": "artifacts/skyrich-tr/dist/public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
